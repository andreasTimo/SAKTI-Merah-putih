# Native fingerprint agent (runs on the operator PC)
AGENT_HOST=127.0.0.1
AGENT_PORT=7373

# Web app (Docker)
PORT=8080
# From inside Docker on Windows/macOS the host is host.docker.internal.
# On a Linux host, use http://172.17.0.1:7373 or run the app without Docker.
AGENT_URL=http://host.docker.internal:7373

# Cloud Run: browser calls this loopback agent directly; Cloud Run can never
# access the operator's USB device. Set the exact deployed HTTPS origin below
# on each Windows operator PC before starting `npm run agent`.
# CAPTURE_TRANSPORT=browser-local
# LOCAL_AGENT_URL=http://127.0.0.1:7373
# AGENT_ALLOWED_ORIGINS=https://YOUR_CLOUD_RUN_URL
SSH_pass=


GCP_Email1= 

GCP_Email2= 

GCP_Email3= 

GCP_Password= 

DB_CONNECTION=pgsql
DB_HOST=ip
DB_PORT=Port
DB_DATABASE=dbname
DB_USERNAME=username
DB_PASSWORD=dbpassword