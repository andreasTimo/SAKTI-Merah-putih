{
  "name": "sakti-merah-putih",
  "version": "0.1.0",
  "private": true,
  "description": "SAKTI Merah Putih — digitalisasi registrasi anggota koperasi (e-KTP NFC + biometrik sidik jari CS9711).",
  "workspaces": [
    "agent"
  ],
  "scripts": {
    "postinstall": "node scripts/setup.js --quiet",
    "setup": "node scripts/setup.js",
    "doctor": "node agent/src/doctor.js",
    "proof": "node agent/src/doctor.js --capture",
    "agent": "node scripts/start-agent.js",
    "agent:windows": "node scripts/start-agent.js",
    "agent:loop-verify": "node scripts/agent-loop-verify.js",
    "agent:motion-step": "node scripts/agent-motion-step.js",
    "app": "docker compose up --build",
    "app:down": "docker compose down"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
